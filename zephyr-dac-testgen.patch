+
+static int cmd_dac_set_mv(const struct shell *sh, size_t argc, char **argv)
+{
+	unsigned long mv = strtoul(argv[1], NULL, 10);
+
+	if (mv > DAC_REF_MV) {
+		shell_error(sh, "Max voltage is %d mV", DAC_REF_MV);
+		return -EINVAL;
+	}
+
+	ramp_running = false;
+
+	uint32_t dac_val = (uint32_t)((uint64_t)mv * DAC_MAX_VALUE / DAC_REF_MV);
+	int ret = dac_write_value(dac_dev, DAC_CHANNEL_ID, dac_val);
+
+	if (ret != 0) {
+		shell_error(sh, "dac_write_value() failed: %d", ret);
+		return ret;
+	}
+
+	shell_print(sh, "DAC ch%d = %lu mV (raw %u/%u)",
+		    DAC_CHANNEL_ID, mv, dac_val, DAC_MAX_VALUE);
+	return 0;
+}
+
+static int cmd_dac_set_raw(const struct shell *sh, size_t argc, char **argv)
+{
+	unsigned long val = strtoul(argv[1], NULL, 10);
+
+	if (val > DAC_MAX_VALUE) {
+		shell_error(sh, "Max raw value is %u", DAC_MAX_VALUE);
+		return -EINVAL;
+	}
+
+	ramp_running = false;
+
+	int ret = dac_write_value(dac_dev, DAC_CHANNEL_ID, (uint32_t)val);
+
+	if (ret != 0) {
+		shell_error(sh, "dac_write_value() failed: %d", ret);
+		return ret;
+	}
+
+	unsigned long mv = (uint64_t)val * DAC_REF_MV / DAC_MAX_VALUE;
+
+	shell_print(sh, "DAC ch%d = raw %lu (~%lu mV)",
+		    DAC_CHANNEL_ID, val, mv);
+	return 0;
+}
+
+static int cmd_dac_ramp(const struct shell *sh, size_t argc, char **argv)
+{
+	unsigned long step = strtoul(argv[1], NULL, 10);
+
+	if (step == 0 || step > DAC_MAX_VALUE) {
+		shell_error(sh, "Step must be 1-%u", DAC_MAX_VALUE);
+		return -EINVAL;
+	}
+
+	ramp_step = (uint32_t)step;
+	ramp_reverse = false;
+	ramp_running = true;
+
+	uint32_t steps = (DAC_MAX_VALUE / (uint32_t)step) + 1;
+	uint32_t period_ms = steps * DAC_RAMP_SLEEP_MS;
+
+	shell_print(sh, "Ramping up with step %lu (%u steps, ~%u ms period)",
+		    step, steps, period_ms);
+	return 0;
+}
+
+static int cmd_dac_ramp_down(const struct shell *sh, size_t argc, char **argv)
+{
+	unsigned long step = strtoul(argv[1], NULL, 10);
+
+	if (step == 0 || step > DAC_MAX_VALUE) {
+		shell_error(sh, "Step must be 1-%u", DAC_MAX_VALUE);
+		return -EINVAL;
+	}
+
+	ramp_step = (uint32_t)step;
+	ramp_reverse = true;
+	ramp_running = true;
+
+	uint32_t steps = (DAC_MAX_VALUE / (uint32_t)step) + 1;
+	uint32_t period_ms = steps * DAC_RAMP_SLEEP_MS;
+
+	shell_print(sh, "Ramping down with step %lu (%u steps, ~%u ms period)",
+		    step, steps, period_ms);
+	return 0;
+}
+
+static int cmd_dac_stop(const struct shell *sh, size_t argc, char **argv)
+{
+	ramp_running = false;
+	shell_print(sh, "Ramp stopped");
+	return 0;
+}
+
+SHELL_STATIC_SUBCMD_SET_CREATE(sub_dac,
+	SHELL_CMD_ARG(mv, NULL, "Set DAC output in millivolts: dac mv <0-3300>",
+		      cmd_dac_set_mv, 2, 0),
+	SHELL_CMD_ARG(raw, NULL, "Set DAC raw value: dac raw <0-4095>",
+		      cmd_dac_set_raw, 2, 0),
+	SHELL_CMD_ARG(ramp, NULL, "Start ramp up: dac ramp <step>",
+		      cmd_dac_ramp, 2, 0),
+	SHELL_CMD_ARG(ramp_down, NULL, "Start ramp down: dac ramp_down <step>",
+		      cmd_dac_ramp_down, 2, 0),
+	SHELL_CMD(stop, NULL, "Stop ramp", cmd_dac_stop),
+	SHELL_SUBCMD_SET_END
+);
+
+SHELL_CMD_REGISTER(dac, &sub_dac, "DAC commands", NULL);
