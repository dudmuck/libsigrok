+/*
+ * Load per-device analog calibration from Logic 2's .cal file.
+ * The file is JSON stored at ~/.config/Logic/calibrations/{serial}-*.cal
+ * and contains fullScaleVoltageRanges with per-channel min/max voltages.
+ * We parse minimumVoltage and maximumVoltage without a JSON library.
+ */
+SR_PRIV void saleae_logic_pro_load_calibration(const struct sr_dev_inst *sdi)
+{
+	struct dev_context *devc = sdi->priv;
+	const char *home;
+	GDir *dir;
+	const gchar *filename;
+	gchar *cal_dir, *cal_path, *contents;
+	gsize length;
+	uint64_t serial_id;
+	char serial_prefix[24];
+	const char *p;
+	unsigned int ch;
+
+	home = g_get_home_dir();
+	if (!home)
+		return;
+
+	cal_dir = g_build_filename(home, ".config", "Logic",
+				   "calibrations", NULL);
+	dir = g_dir_open(cal_dir, 0, NULL);
+	if (!dir) {
+		sr_dbg("No calibration directory: %s", cal_dir);
+		g_free(cal_dir);
+		return;
+	}
+
+	/* Construct the serial number as a uint64 (little-endian). */
+	serial_id = 0;
+	for (int i = 0; i < 8; i++)
+		serial_id |= (uint64_t)devc->eeprom_serial[i] << (i * 8);
+	snprintf(serial_prefix, sizeof(serial_prefix),
+		 "%" PRIu64 "-", serial_id);
+
+	/* Find a .cal file matching the serial. */
+	cal_path = NULL;
+	while ((filename = g_dir_read_name(dir)) != NULL) {
+		if (g_str_has_prefix(filename, serial_prefix) &&
+		    g_str_has_suffix(filename, ".cal")) {
+			cal_path = g_build_filename(cal_dir, filename, NULL);
+			break;
+		}
+	}
+	g_dir_close(dir);
+	g_free(cal_dir);
+
+	if (!cal_path) {
+		sr_dbg("No calibration file found for serial %" PRIu64 ".",
+		       serial_id);
+		return;
+	}
+
+	if (!g_file_get_contents(cal_path, &contents, &length, NULL)) {
+		sr_warn("Failed to read calibration file: %s", cal_path);
+		g_free(cal_path);
+		return;
+	}
+	sr_info("Loading calibration from %s", cal_path);
+	g_free(cal_path);
+
+	/*
+	 * Parse fullScaleVoltageRanges array. The format is:
+	 * "fullScaleVoltageRanges":[
+	 *   {"minimumVoltage":-0.498883,"maximumVoltage":5.237675},
+	 *   ...
+	 * ]
+	 */
+	p = strstr(contents, "\"fullScaleVoltageRanges\"");
+	if (!p) {
+		sr_warn("Calibration file missing fullScaleVoltageRanges.");
+		g_free(contents);
+		return;
+	}
+
+	p = strchr(p, '[');
+	if (!p) {
+		g_free(contents);
+		return;
+	}
+
+	for (ch = 0; ch < LOGIC8_MAX_ANA_CHANNELS && *p; ch++) {
+		const char *min_key, *max_key;
+		float vmin, vmax;
+
+		min_key = strstr(p, "\"minimumVoltage\"");
+		if (!min_key || min_key > strchr(p, ']'))
+			break;
+		min_key = strchr(min_key, ':');
+		if (!min_key)
+			break;
+		vmin = (float)g_ascii_strtod(min_key + 1, NULL);
+
+		max_key = strstr(min_key, "\"maximumVoltage\"");
+		if (!max_key)
+			break;
+		max_key = strchr(max_key, ':');
+		if (!max_key)
+			break;
+		vmax = (float)g_ascii_strtod(max_key + 1, NULL);
+
+		devc->ana_vmin[ch] = vmin;
+		devc->ana_vmax[ch] = vmax;
+
+		sr_dbg("CH%u calibration: %.4f V to %.4f V", ch, vmin, vmax);
+
+		/* Advance past this entry. */
+		p = strchr(max_key, '}');
+		if (!p)
+			break;
+		p++;
+	}
+
+	if (ch == LOGIC8_MAX_ANA_CHANNELS) {
+		devc->ana_calibrated = TRUE;
+		sr_info("Loaded calibration for %u analog channels.", ch);
+	} else {
+		sr_warn("Calibration incomplete: only %u channels.", ch);
+	}
+
+	g_free(contents);
+}
