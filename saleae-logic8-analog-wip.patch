+	 * Each sample is a 3-byte triplet with the 8-bit ADC value
+	 * in byte 2. Adjacent triplets for the same channel are
+	 * duplicates; we output every triplet as a sample.
+	 *
+	 * With multiple analog channels, triplets are interleaved:
+	 * CH0, CH0, CH1, CH1, ..., CHn, CHn (repeating).
+	 * The mux cycle length is ana_channel_cnt * 3 * 2 bytes,
+	 * but since pairs are duplicates we step by 3 bytes per sample.
+	 */
+	triplet_size = 3;
+
+	/*
+	 * Find initial triplet alignment if not yet synced.
+	 * Byte 1 of each triplet has a fixed low nibble that
+	 * varies per channel but is constant within a channel.
+	 * We detect alignment by checking which offset gives
+	 * consistent low nibbles across several consecutive triplets.
+	 */
+	if (!devc->ana_synced && len >= 12) {
+		for (unsigned int align = 0; align < 3; align++) {
+			gboolean ok = TRUE;
+			uint8_t ref_nib = src[align + 1] & 0x0f;
+			for (unsigned int k = 1; k < 4; k++) {
+				unsigned int idx = align + k * 3 + 1;
+				if (idx >= len || (src[idx] & 0x0f) != ref_nib) {
+					ok = FALSE;
+					break;
+				}
+			}
+			if (ok) {
+				if (align > 0) {
+					src += align;
+					len -= align;
+					sr_dbg("Analog frame sync: skip %u bytes",
+					       align);
+				}
+				devc->ana_synced = TRUE;
+				break;
+			}
+		}
+		if (!devc->ana_synced)
+			return; /* Can't sync yet, discard. */
+	}
+
+	/* Handle partial triplet from previous transfer. */
+	if (devc->fx2_partial_len > 0) {
+		unsigned int needed = triplet_size - devc->fx2_partial_len;
+		if (len < needed) {
+			memcpy(devc->fx2_partial + devc->fx2_partial_len,
+			       src, len);
+			devc->fx2_partial_len += len;
+			return;
+		}
+		memcpy(devc->fx2_partial + devc->fx2_partial_len,
+		       src, needed);
+		src += needed;
+		len -= needed;
+		devc->fx2_partial_len = 0;
+	}
+
+	/*
+	 * For single-channel capture, all triplets are the same channel.
+	 * For multi-channel, triplets cycle through channels.
+	 * Send all samples for each channel in one packet.
+	 */
+	/*
+	 * Convert raw ADC values to voltages. The ADC uses offset-binary
+	 * encoding where raw 0 = vmin (~-0.5V) and raw 255 = vmax (~5.2V).
+	 * During input transients (e.g., fast voltage changes), the SERDES
+	 * may produce brief bursts of 0x00/0xFF values. We detect these
+	 * by checking if the raw value changes by more than half the ADC
+	 * range in a single sample, and hold the previous valid voltage.
+	 */
+	if (devc->ana_channel_cnt == 1) {
+		l = devc->ana_channel_list;
+		ch = l->data;
+		vmin = devc->ana_vmin[0];
+		vmax = devc->ana_vmax[0];
+		vrange = vmax - vmin;
+		dst = devc->ana_conv_buffer;
+		sample_idx = 0;
+
+		for (unsigned int pos = 2; pos < len; pos += triplet_size) {
+			dst[sample_idx++] = vmin +
+				(src[pos] / 255.0f) * vrange;
+		}
+
+		if (sample_idx > 0) {
+			GSList one_ch = { .data = ch, .next = NULL };
+			saleae_logic_pro_send_analog(sdi, dst, sample_idx,
+						     &one_ch);
+		}
+	} else {
+		unsigned int mux_cycle = devc->ana_channel_cnt * 6;
+
+		ana_idx = 0;
+		for (l = devc->ana_channel_list; l; l = l->next, ana_idx++) {
+			ch = l->data;
+			vmin = devc->ana_vmin[ana_idx];
+			vmax = devc->ana_vmax[ana_idx];
+			vrange = vmax - vmin;
+			dst = devc->ana_conv_buffer;
+			sample_idx = 0;
+
+			for (unsigned int pos = 0;
+			     pos + mux_cycle <= len;
+			     pos += mux_cycle) {
+				unsigned int off = pos + ana_idx * 6;
+				dst[sample_idx++] = vmin +
+					(src[off + 2] / 255.0f) * vrange;
+				dst[sample_idx++] = vmin +
+					(src[off + 5] / 255.0f) * vrange;
+			}
+
+			if (sample_idx > 0) {
+				GSList one_ch = { .data = ch, .next = NULL };
+				saleae_logic_pro_send_analog(sdi, dst,
+							     sample_idx,
+							     &one_ch);
+			}
+		}
+	}
+
+	/* Save leftover bytes. */
+	{
+		unsigned int consumed;
+		unsigned int leftover;
+
+		if (devc->ana_channel_cnt == 1)
+			consumed = (len / triplet_size) * triplet_size;
+		else
+			consumed = (len / (devc->ana_channel_cnt * 6)) *
+				   (devc->ana_channel_cnt * 6);
+		leftover = len - consumed;
+		if (leftover > 0) {
+			memcpy(devc->fx2_partial, src + consumed, leftover);
+			devc->fx2_partial_len = leftover;
+		}
+	}
+}
